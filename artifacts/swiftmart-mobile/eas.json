{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.18.1",
      "env": {
        "EAS_NO_NPM_CI": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.18.1",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EAS_NO_NPM_CI": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "20.18.1",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EAS_NO_NPM_CI": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
